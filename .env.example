# Required: OpenAI API key used by LangChain/OpenAI calls.
OPENAI_API_KEY=replace-me

# Required for the Telegram polling bot. Do not commit your real token.
TELEGRAM_BOT_TOKEN=replace-me

# Required in production for Telegram access-control key digests.
# Generate with: python - <<'PY'
# import secrets; print(secrets.token_urlsafe(32))
# PY
BOT_AUTH_SECRET=replace-me

# Optional: USDA FoodData Central key. If omitted, the app uses the local fallback table.
USDA_API_KEY=

# Optional model configuration. Override these if your account uses different model names.
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_CRITIC_MODEL=gpt-4.1-mini

# Optional moderation toggle. When disabled or unavailable, conservative local checks still run.
OPENAI_MODERATION_ENABLED=true

# Optional local paths.
NUTRITION_CACHE_DIR=.cache/nutrition-agent
TEMP_IMAGE_DIR=/tmp/nutrition-agent-images
AUTH_DB_PATH=data/auth.sqlite3

# Optional Phoenix tracing. Disabled by default.
# Start the self-hosted Phoenix collector first, then set ENABLE_PHOENIX_TRACING=true.
ENABLE_PHOENIX_TRACING=false
PHOENIX_PROJECT_NAME=nutrition-agent
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces
